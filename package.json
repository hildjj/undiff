{
  "name": "undiff",
  "displayName": "undiff",
  "description": "Remove plus signs at the beginning of lines in the current selection.",
  "version": "0.0.1",
  "activationEvents": [],
  "main": "./out/extension.js",
  "repository": "hildjj/undiff",
  "contributes": {
    "commands": [
      {
        "command": "undiff.unPlus",
        "title": "Undiff: Remove leading plus"
      },
      {
        "command": "undiff.unMinus",
        "title": "Undiff: Remove leading minus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.102.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "eslint": "^9.32.0",
    "typescript": "^5.8.3",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  },
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "vscode": "^1.102.0"
  }
}
