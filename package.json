{
  "name": "undiff",
  "displayName": "undiff",
  "description": "Remove plus signs at the beginning of lines in the current selection.",
  "version": "0.0.1",
  "activationEvents": [],
  "main": "./out/extension.js",
  "repository": "hildjj/undiff",
  "contributes": {
    "commands": [
      {
        "command": "undiff.unPlus",
        "title": "Undiff: Remove leading plus"
      },
      {
        "command": "undiff.unMinus",
        "title": "Undiff: Remove leading minus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.110.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^10.1.0",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "mocha@11.7.5>diff": "8.0.3",
      "mocha@11.7.5>serialize-javascript": "7.0.4"
    }
  },
  "engines": {
    "vscode": "^1.102.0"
  }
}
